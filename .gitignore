# ---- Public-release exclusions: regenerable large artifacts ----
# Per-corpus full SQLite score DBs (regenerate with `make -C outputs/code score-db`;
# the lean evidence DB is embedded in the Evidence Explorer and shipped separately).
outputs/results/**/piper_scores.db
outputs/figures/manuscript/PIPER_ATLAS/piper_atlas.db
outputs/figures/manuscript/PIPER_EVIDENCE_EXPLORER/piper_evidence_explorer.db
# Harmonized long-format tables (regenerate from catalogs via the harmonize step).
data/deg/harmonized/*_harmonized.csv
data/deg/harmonized/*_harmonized.parquet
# Large per-corpus score CSVs (regenerate via score-db).
outputs/results/**/piper_gene_scores.csv
# Large raw reference downloads (re-download from the documented source URLs).
data/deg/raw/microarray/GPL17077_platform.txt
data/deg/raw/ifn/hgnc_complete_set.txt
# Additional regenerable large intermediates (slice harmonized, rank-plane points, derived matrices).
outputs/results/**/slice_harmonized.csv
outputs/results/**/rank_plane_points.csv
data/deg/raw/microarray_cross_platform/GSE19519_ER_STRESS_LCL_probe_gene_matrix.csv
data/deg/raw/microarray_cross_platform/*_series_matrix.txt.gz

# ---- DEGORA-rename update (2026-05-31): exclude all large regenerable artifacts ----
# The piper_* patterns above predate the degora rename; the pipeline now emits
# degora_*-prefixed files. Per release policy, commit only paper-related source/text
# and curated panels; never commit large regenerable inputs or score artifacts.

# All raw + harmonized DEG input data (large; re-download/regenerate from catalogs).
data/deg/

# Per-corpus SQLite score DBs and large score/intermediate tables (regenerate via `make -C outputs/code score-db` / `paper`).
outputs/results/**/*.db
outputs/results/**/*.parquet
outputs/results/**/degora_gene_scores.csv
outputs/results/**/slice_consensus.csv
outputs/results/**/rank_plane_gene_summary.csv
outputs/results/**/rank_plane_points.csv

# Old experimental iteration trees (regenerable; not part of the manuscript).
outputs/results/iter-*/

# Comparator baseline outputs: large regenerable per-method TSVs (rerun via `make -C outputs/code baseline`).
outputs/results/**/baselines/

# Indisulam drug pilot: excluded from the manuscript (4 topics are IFN/ER/heat/hypoxia).
outputs/results/indisulam*/

# Large interactive figure artifacts (regenerable; Explorer/Atlas DBs + HTML shipped separately).
outputs/figures/manuscript/**/*.db
outputs/figures/manuscript/**/*.html
outputs/figures/manuscript/DEGORA_ATLAS/degora_atlas_gene_index.csv
outputs/figures/manuscript/DEGORA_ATLAS/degora_atlas_source_data.xlsx

# Vendored external comparator tool (MAIC); cloned on demand by the maic-comparator make target.
outputs/code/vendor/
