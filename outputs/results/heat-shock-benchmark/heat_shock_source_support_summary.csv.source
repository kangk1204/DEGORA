env PYTHONPATH=outputs/code python outputs/code/scripts/write_source_support_report.py --score-csv outputs/results/heat-shock-benchmark/piper_gene_scores.csv --gold data/studies/gold/heat_shock_hsf1_gold_panel.csv --gold-gene-column gene_symbol --rank-column piper_rank --direction-column consensus_direction --top-n 20 --cutoffs 10 20 50 100 --min-source-units 2 --min-sign-concordance 1.0 --title 'Heat Shock / HSF1 Source-Support Report' --output-summary-csv outputs/results/heat-shock-benchmark/heat_shock_source_support_summary.csv --output-top-tsv outputs/results/heat-shock-benchmark/heat_shock_source_support_top_genes.tsv --output-json outputs/results/heat-shock-benchmark/heat_shock_source_support_report.json --output-md outputs/results/heat-shock-benchmark/heat_shock_source_support_report.md
