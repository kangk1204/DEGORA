env PYTHONPATH=outputs/code python outputs/code/scripts/write_source_support_report.py --score-csv outputs/results/ifn-pilot/piper_gene_scores.csv --gold data/studies/gold/ifn_gold_panel.csv --marker-panel data/studies/interpretive/ifn_type_i_marker_panel.csv --gold-gene-column gene_symbol --rank-column piper_rank --direction-column consensus_direction --top-n 10 --cutoffs 10 20 50 100 --min-source-units 2 --min-sign-concordance 1.0 --title 'IFN PIPER Source-Support Report' --output-summary-csv outputs/results/ifn-pilot/ifn_source_support_summary.csv --output-top-tsv outputs/results/ifn-pilot/ifn_source_support_top_genes.tsv --output-json outputs/results/ifn-pilot/ifn_source_support_report.json --output-md outputs/results/ifn-pilot/ifn_source_support_report.md
